s":["Containergi2y1"],"componentType":"Page","uiType":"TransparentPageSkin","pageId":"gi2y1"},"comp-mim70eck":{"components":["comp-mim70edk"],"componentType":"ClassicSection","pageId":"gi2y1"},"comp-min23asr":{"components":["comp-min23rqg","comp-mim70eei4"],"componentType":"ClassicSection","pageId":"gi2y1"},"comp-mim70edk":{"components":["comp-mim70edw","comp-mim70efd2"],"componentType":"StripColumnsContainer","uiType":"DesignedStrip","pageId":"gi2y1"},"comp-mim70edw":{"components":["comp-mim70edx5","comp-mim70eef","comp-mim70eeh2","comp-mio1ryux","comp-mio1uhn5","comp-mio1ryty","comp-mio1ve0d"],"componentType":"Column","uiType":"DefaultColumn","pageId":"gi2y1"},"comp-mim70efd2":{"components":[],"componentType":"Column","uiType":"DesignedColumn","pageId":"gi2y1"},"Containergi2y1":{"components":["comp-mim70eck","comp-min23asr"],"componentType":"Group","pageId":"gi2y1"}},"features":["accessibilityBrowserZoom","clickHandlerRegistrar","components","domSelectors","environmentService","imagePlaceholder","landingPage","mpaNavigation","navigationManager","pageAnchors","pageTransitions","renderer","reporter","scrollRestoration","scrollToAnchor","seo","windowScroll","wixEmbedsApi","componentsLoader"],"siteFeaturesConfigs":null},"props":{"render":{"compProps":{"comp-min23rqg":{"html":"<p class=\"font_8 wixui-rich-text__text\" style=\"font-size:18px;\"><span style=\"font-size:18px;\" class=\"wixui-rich-text__text\">As a social critic and political essayist, Heather M. Edwards (<span style=\"text-decoration:underline;\" class=\"wixui-rich-text__text\"><a href=\"https://pronouns.org/what-and-why\" target=\"_blank\" rel=\"noreferrer noopener\" class=\"wixui-rich-text__text\">she/her</a></span>) writes news articles, feature pieces, human interest stories, interviews,&nbsp;<span style=\"text-decoration:underline;\" class=\"wixui-rich-text__text\"><a href=\"https://rotarydistrict5110.com/\" target=\"_blank\" rel=\"noreferrer noopener\" class=\"wixui-rich-text__text\">website copy</a></span>, newsletters, and blog posts for mission-driven organizations and publications. She is a co-founding member of Las Escritoras, a multi-genre writing, editing, and beta reader cooperative based in Guadalajara, Mexico. She also writes about empowering community and economic development projects and programs that&nbsp;<span style=\"text-decoration:underline;\" class=\"wixui-rich-text__text\"><a href=\"https://rotarydistrict5110.com/author/heather/\" target=\"_blank\" rel=\"noreferrer noopener\" class=\"wixui-rich-text__text\">Rotary International</a></span>&nbsp;does locally, regionally, and globally.​</span></p>\n\n<p class=\"font_8 wixui-rich-text__text\" style=\"font-size:18px;\"><span style=\"font-size:18px;\" class=\"wixui-rich-text__text\">​​​</span></p>\n\n<p class=\"font_8 wixui-rich-text__text\" style=\"font-size:18px;\"><span style=\"font-size:18px;\" class=\"wixui-rich-text__text\">Published in:&nbsp;<span style=\"text-decoration:underline;\" class=\"wixui-rich-text__text\"><a href=\"https://goodmenproject.com/author/heather-m-edwards/\" target=\"_blank\" rel=\"noreferrer noopener\" class=\"wixui-rich-text__text\">The Good Men Project</a></span>,&nbsp;<span style=\"text-decoration:underline;\" class=\"wixui-rich-text__text\"><a href=\"https://heathermedwards.medium.com/ove-tova-and-iona-iverson-how-popular-novels-are-vibrantly-rewriting-aging-88420d99d7dc?source=user_profile_page---------23-------------7dda6e72d089----------------------\" target=\"_blank\" rel=\"noreferrer noopener\" class=\"wixui-rich-text__text\">Counter Arts</a></span>,&nbsp;<span style=\"text-decoration:underline;\" class=\"wixui-rich-text__text\"><a href=\"https://prowritingaid.com/art/1007/a-case-for-lowercase.aspx\" target=\"_blank\" rel=\"noreferrer noopener\" class=\"wixui-rich-text__text\">ProWritingAid</a></span>,&nbsp;<span style=\"text-decoration:underline;\" class=\"wixui-rich-text__text\"><a href=\"https://writingcooperative.com/the-dictionary-of-obscure-sorrows-d1688040bd26\" target=\"_blank\" rel=\"noreferrer noopener\" class=\"wixui-rich-text__text\">The Writing Cooperative</a></span>,&nbsp;<span style=\"text-decoration:underline;\" class=\"wixui-rich-text__text\"><a href=\"https://medium.com/writers-guild/the-anglophone-advantage-b9e583c5a9d4\" target=\"_blank\" rel=\"noreferrer noopener\" class=\"wixui-rich-text__text\">Writers Guild</a></span>,&nbsp;<span style=\"text-decoration:underline;\" class=\"wixui-rich-text__text\"><a href=\"https://heathermedwards.medium.com/when-someone-elses-memories-become-your-mysteries-62abdeeb2da3?source=user_profile_page---------19-------------7dda6e72d089----------------------\" target=\"_blank\" rel=\"noreferrer noopener\" class=\"wixui-rich-text__text\">Publishous</a></span>,&nbsp;<span style=\"text-decoration:underline;\" class=\"wixui-rich-text__text\"><a href=\"https://medium.com/swlh/nobody-goes-to-mars-until-everybody-eats-6e5ec098cddb\" target=\"_blank\" rel=\"noreferrer noopener\" class=\"wixui-rich-text__text\">The Startup</a></span>,&nbsp;<span style=\"text-decoration:underline;\" class=\"wixui-rich-text__text\"><a href=\"https://medium.com/the-ascent/routine-matters-more-than-ritual-848ee0caf5ee\" target=\"_blank\" rel=\"noreferrer noopener\" class=\"wixui-rich-text__text\">The Ascent</a></span>,&nbsp;<span style=\"text-decoration:underline;\" class=\"wixui-rich-text__text\"><a href=\"https://heathermedwards.medium.com/dr-trump-dystopian-novels-and-channeling-your-outrage-5b4df08c1a13?source=user_profile_page---------70-------------7dda6e72d089----------------------\" target=\"_blank\" rel=\"noreferrer noopener\" class=\"wixui-rich-text__text\">The Political Prism</a></span>,&nbsp;<span style=\"text-decoration:underline;\" class=\"wixui-rich-text__text\"><a href=\"https://heathermedwards.medium.com/the-catholic-nuns-and-priests-fighting-for-vulnerable-people-d31381872ae6?source=user_profile_page---------11-------------7dda6e72d089----------------------\" target=\"_blank\" rel=\"noreferrer noopener\" class=\"wixui-rich-text__text\">Interfaith Now</a></span>,&nbsp;<span style=\"text-decoration:underline;\" class=\"wixui-rich-text__text\"><a href=\"https://medium.com/equality-includes-you/american-scientists-are-now-academic-refugees-finding-asylum-in-france-1cc088de1881?source=user_profile_page---------6-------------7dda6e72d089----------------------\" target=\"_blank\" rel=\"noreferrer noopener\" class=\"wixui-rich-text__text\">Equality Includes You</a></span><a href=\"https://medium.com/equality-includes-you/american-scientists-are-now-academic-refugees-finding-asylum-in-france-1cc088de1881?source=user_profile_page---------6-------------7dda6e72d089----------------------\" target=\"_blank\" rel=\"noreferrer noopener\" class=\"wixui-rich-text__text\">, The Register-Guard, The Cottage Grove Sentinel, The Creswell Chronicle, the Drain Enterprise, The Torch, and Denali Literary Arts Journal</a>​</span></p>\n\n<p class=\"font_8 wixui-rich-text__text\" style=\"font-size:18px;\"><span style=\"font-size:18px;\" class=\"wixui-rich-text__text\">​</span></p>\n\n<p class=\"font_8 wixui-rich-text__text\" style=\"font-size:18px;\"><span style=\"font-size:18px;\" class=\"wixui-rich-text__text\"><span style=\"text-decoration:underline;\" class=\"wixui-rich-text__text\"><a href=\"https://www.linkedin.com/in/heathermedwards/\" target=\"_blank\" rel=\"noreferrer noopener\" class=\"wixui-rich-text__text\">Want to connect on LinkedIn</a><a href=\"https://www.linkedin.com/in/heathermedwards/\" target=\"_blank\" rel=\"noreferrer noopener\" class=\"wixui-rich-text__text\">?</a></span></span></p>\n\n<p class=\"font_8 wixui-rich-text__text\" style=\"font-size:18px;\"><span style=\"font-size:18px;\" class=\"wixui-rich-text__text\">​</span></p>\n\n<p class=\"font_8 wixui-rich-text__text\" style=\"font-size:18px; line-height:1.4em;\"><span style=\"font-size:18px;\" class=\"wixui-rich-text__text\"><span style=\"text-decoration:underline;\" class=\"wixui-rich-text__text\"><a href=\"https://www.goodreads.com/user/show/73380796?ref=nav_profile_l\" target=\"_blank\" rel=\"noreferrer noopener\" class=\"wixui-rich-text__text\">See what I&#39;m reading.</a></span></span></p>\n\n<p class=\"font_8 wixui-rich-text__text\" style=\"font-size:18px; line-height:1.4em;\"><span style=\"font-size:18px;\" class=\"wixui-rich-text__text\"><span style=\"text-decoration:underline;\" class=\"wixui-rich-text__text\"><span class=\"wixui-rich-text__text\">​</span></span></span><span style=\"font-size:18px;\" class=\"wixui-rich-text__text\"><span style=\"text-decoration:underline;\" class=\"wixui-rich-text__text\"><span class=\"wixGuard wixui-rich-text__text\">​</span></span></span></p>","skin":"WRichTextThemeSkin","isQaMode":false,"fullNameCompType":"wysiwyg.viewer.components.WRichText"},"comp-mim70eei4":{"images":[{"alt":"LinkedIn","width":200,"height":200,"uri":"11062b_60c5fc4a3ecd49f2a697206b09eeace1~mv2.png","title":"LinkedIn","containerId":"dataItem-mim70ef3-comp-mim70eei4","hasBgScrollEffect":"","bgEffectName":"","displayMode":"fill","link":{"href":"https://www.linkedin.com/in/heathermedwards/?lipi=urn%3Ali%3Apage%3Ad_flagship3_feed%3Bv42cjmHSQ1OVQy9Jp0Z%2Buw%3D%3D","target":"_blank","rel":"noreferrer noopener","type":"ExternalLink","id":"dataItem-mim70ef31"},"encoding":"AVIF","allowWebpAvifTransforms":true,"responsiveImageProps":{"fallbackSrc":"https://static.wixstatic.com/media/11062b_60c5fc4a3ecd49f2a697206b09eeace1~mv2.png/v1/fill/w_34,h_34,al_c,q_85,usm_0.66_1.00_0.01,enc_avif,quality_auto/11062b_60c5fc4a3ecd49f2a697206b09eeace1~mv2.png","srcset":"https://static.wixstatic.com/media/11062b_60c5fc4a3ecd49f2a697206b09eeace1~mv2.png/v1/fill/w_34,h_34,al_c,q_85,usm_0.66_1.00_0.01,enc_avif,quality_auto/11062b_60c5fc4a3ecd49f2a697206b09eeace1~mv2.png 1x, https://static.wixstatic.com/media/11062b_60c5fc4a3ecd49f2a697206b09eeace1~mv2.png/v1/fill/w_68,h_68,al_c,q_85,usm_0.66_1.00_0.01,enc_avif,quality_auto/11062b_60c5fc4a3ecd49f2a697206b09eeace1~mv2.png