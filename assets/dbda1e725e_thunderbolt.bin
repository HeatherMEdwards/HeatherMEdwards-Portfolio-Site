3750734d058339e5fb23c4e4a4~mv2.jpg 2x","css":{"container":{"position":"relative"},"img":{"width":155,"height":234,"objectFit":"cover"}}},"containerWidth":155,"containerHeight":234,"isInFirstFold":true,"crop":null,"onClickBehavior":"goToLink","fullNameCompType":"wysiwyg.viewer.components.WPhoto","language":"en","compId":"comp-mi99i6hz","mainPageId":"gi2y1","trackClicksAnalytics":false,"popupA11yExperimentEnabled":false,"translations":{"expandAriaLabel":"Expand image","zoomInButtonAriaLabel":"Zoom in"},"zoomedImageResponsiveOverride":{},"allowFullGIFTransformation":false},"comp-mi99kusz":{"html":"<p class=\"font_8 wixui-rich-text__text\" style=\"font-size:17px; line-height:normal;\"><span style=\"font-size:17px;\" class=\"wixui-rich-text__text\"><span style=\"font-weight:normal;\" class=\"wixui-rich-text__text\"><span style=\"font-family:cormorantgaramond-semibold,cormorantgaramond,cormorant garamond,serif;\" class=\"wixui-rich-text__text\"><span style=\"letter-spacing:normal;\" class=\"wixui-rich-text__text\">Greetings, fellow writers and readers ~​ </span></span></span></span></p>\n\n<p class=\"font_8 wixui-rich-text__text\" style=\"font-size:17px; line-height:normal;\">&nbsp;</p>\n\n<p class=\"font_8 wixui-rich-text__text\" style=\"font-size:17px; line-height:normal;\"><span style=\"font-size:17px;\" class=\"wixui-rich-text__text\"><span style=\"font-weight:normal;\" class=\"wixui-rich-text__text\"><span style=\"font-family:cormorantgaramond-semibold,cormorantgaramond,cormorant garamond,serif;\" class=\"wixui-rich-text__text\"><span style=\"letter-spacing:normal;\" class=\"wixui-rich-text__text\">The internet is a such a vast, saturated place. If you&#39;ve found yourself here, thank you for reading. ​​​&nbsp;</span></span></span></span></p>\n\n<p class=\"font_8 wixui-rich-text__text\" style=\"font-size:17px; line-height:normal;\">&nbsp;</p>\n\n<p class=\"font_8 wixui-rich-text__text\" style=\"font-size:17px; line-height:normal;\"><span style=\"font-size:17px;\" class=\"wixui-rich-text__text\"><span style=\"font-weight:normal;\" class=\"wixui-rich-text__text\"><span style=\"font-family:cormorantgaramond-semibold,cormorantgaramond,cormorant garamond,serif;\" class=\"wixui-rich-text__text\"><span style=\"letter-spacing:normal;\" class=\"wixui-rich-text__text\">I write about faith, politics, and social justice in the hope of creating a sense of community and collective direction during these volatile times in the U.S.</span></span></span></span></p>\n\n<p class=\"font_8 wixui-rich-text__text\" style=\"font-size:17px; line-height:normal;\"><span style=\"font-size:17px;\" class=\"wixui-rich-text__text\"><span style=\"font-weight:normal;\" class=\"wixui-rich-text__text\"><span style=\"font-family:cormorantgaramond-semibold,cormorantgaramond,cormorant garamond,serif;\" class=\"wixui-rich-text__text\"><span style=\"letter-spacing:normal;\" class=\"wixui-rich-text__text\">​</span></span></span></span></p>\n\n<p class=\"font_8 wixui-rich-text__text\" style=\"font-size:17px; line-height:normal;\"><span style=\"font-size:17px;\" class=\"wixui-rich-text__text\"><span style=\"font-weight:normal;\" class=\"wixui-rich-text__text\"><span style=\"font-family:cormorantgaramond-semibold,cormorantgaramond,cormorant garamond,serif;\" class=\"wixui-rich-text__text\"><span style=\"letter-spacing:normal;\" class=\"wixui-rich-text__text\">You can also read about inspiring people on my <span style=\"text-decoration:underline;\" class=\"wixui-rich-text__text\"><a href=\"https://www.heathermedwards.com/interviews\" target=\"_blank\" class=\"wixui-rich-text__text\">Interviews</a></span> page, and <span style=\"text-decoration:underline;\" class=\"wixui-rich-text__text\"><a href=\"https://rotarydistrict5110.com/author/heather/\" target=\"_blank\" rel=\"noreferrer noopener\" class=\"wixui-rich-text__text\">local &amp; international development</a></span> on the Rotary District 5110 page. &nbsp;</span></span></span></span></p>","skin":"WRichTextThemeSkin","isQaMode":false,"fullNameCompType":"wysiwyg.viewer.components.WRichText"},"comp-m05qsknr":{"html":"<h2 class=\"font_2 wixui-rich-text__text\" style=\"font-size:25px; line-height:normal; text-align:center;\"><span style=\"font-weight:bold;\" class=\"wixui-rich-text__text\"><span style=\"font-size:25px;\" class=\"wixui-rich-text__text\"><span class=\"color_15 wixui-rich-text__text\"><span style=\"letter-spacing:0.05em;\" class=\"wixui-rich-text__text\"><span style=\"font-family:cormorantgaramond-semibold,cormorantgaramond,cormorant garamond,serif;\" class=\"wixui-rich-text__text\">Published in</span></span></span></span></span></h2>","skin":"WRichTextThemeSkin","isQaMode":false,"fullNameCompType":"wysiwyg.viewer.components.WRichText"},"comp-m04yaqgh":{"uri":"b3430a_32bf64c8eeaa44238914966d19a567d7~mv2.jpeg","width":668,"height":216,"title":"F190B97E-0245-4F4C-94B5-732C511972F1_4_5","containerId":"comp-m04yaqgh","hasBgScrollEffect":"","bgEffectName":"","displayMode":"fill","link":{"href":"https://medium.com/swlh/every-day-do-one-thing-that-scares-you-47c9683fb369","target":"_blank","rel":"noreferrer noopener","type":"ExternalLink","id":"dataItem-m05pq653"},"hasAnimation":false,"encoding":"AVIF","allowWebpAvifTransforms":true,"responsiveImageProps":{"fallbackSrc":"https://static.wixstatic.com/media/b3430a_32bf64c8eeaa44238914966d19a567d7~mv2.jpeg/v1/fill/w_167,h_53,al_c,q_80,usm_0.66_1.00_0.01,enc_avif,quality_auto/b3430a_32bf64c8eeaa44238914966d19a567d7~mv2.jpeg","srcset":"https://static.wixstatic.com/media/b3430a_32bf64c8eeaa44238914966d19a567d7~mv2.jpeg/v1/fill/w_167,h_53,al_c,q_80,usm_0.66_1.00_0.01,enc_avif,quality_auto/b3430a_32bf64c8eeaa44238914966d19a567d7~mv2.jpeg 1x, https://static.wixstatic.com/media/b3430a_32bf64c8eeaa44238914966d19a567d7~mv2.jpeg/v1/fill/w_334,h_106,al_c,q_80,usm_0.66_1.00_0.01,enc_avif,quality_auto/b3430a_32bf64c8eeaa44238914966d19a567d7~mv2.jpeg 2x","css":{"container":{"position":"relative"},"img":{"width":167,"height":53,"objectFit":"cove